SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
ANTHROPIC_API_KEY=sk-ant-...

# 파일 저장 방식 설정
# ─────────────────────────────
# 로컬 저장: 항상 활성 (output_dir에 파일 저장)
# DB 저장: file_data 컬럼에 base64 저장 (소량일 때만 권장, DB 용량 주의)
# Storage 저장: Supabase Storage에 업로드 (Pro 플랜 100GB 포함)
#
# Storage 사용 시:
# 1. Supabase Pro 플랜 구독 ($25/월, 100GB storage 포함)
# 2. SUPABASE_SERVICE_KEY를 service_role 키로 설정 (anon 키 불가)
# 3. ENABLE_STORAGE_UPLOAD=true 로 변경
ENABLE_STORAGE_UPLOAD=false

# DB에 파일 바이너리 저장 (소량 수집 시에만 권장)
# 11만건 기준 ~15GB → DB 용량 초과 주의
ENABLE_DB_FILE_DATA=false
